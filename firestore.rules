rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact messages: Anyone can create, only admin can read/delete
    match /messages/{message} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
    
    // Website content: Publicly readable, admin only can write/edit/delete
    match /services/{id} { allow read: if true; allow write: if request.auth != null; }
    match /portfolio/{id} { allow read: if true; allow write: if request.auth != null; }
    match /testimonials/{id} { allow read: if true; allow write: if request.auth != null; }
    match /settings/{id} { allow read: if true; allow write: if request.auth != null; }
    match /pricing/{id} { allow read: if true; allow write: if request.auth != null; }
  }
}
